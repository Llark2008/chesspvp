{
  "name": "chesspvp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "predev": "pnpm --filter @chesspvp/shared run build",
    "dev": "pnpm -r --parallel --filter=@chesspvp/shared --filter=@chesspvp/client --filter=@chesspvp/server run dev",
    "pretest": "pnpm --filter @chesspvp/shared run build",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
