NODE_ENV=production

# Public web origin for browser CORS checks. Keep HTTP + IP for the first rollout.
CORS_ORIGIN=http://YOUR_SERVER_IP

# Application runtime
PORT=3001
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
VITE_ASSET_PROVIDER=primitive

# Compose interpolation and runtime DB/cache wiring
WEB_IMAGE=ccr.ccs.tencentyun.com/example/chesspvp-web:replace-me
SERVER_IMAGE=ccr.ccs.tencentyun.com/example/chesspvp-server:replace-me
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
POSTGRES_USER=chesspvp
POSTGRES_PASSWORD=change-me
POSTGRES_DB=chesspvp
DATABASE_URL=postgresql://chesspvp:change-me@postgres:5432/chesspvp
REDIS_URL=redis://redis:6379
